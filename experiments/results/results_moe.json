  {
    "template": "evolved_naive_allgather",
    "cost_score": 2.29,
    "sim_time_us": 229.0,
    "num_steps": 1,
    "num_collective_permute": 0,
    "num_all_gather": 1,
    "name": "evo:naive_allgather",
    "params": {
      "evolved_code": "def evolved_alltoallv(input_tensor, send_counts, recv_counts, max_chunk,\n                      rank, world_size, num_devices, cores_per_device,\n                      xm, torch, num_nodes=1):\n    \"\"\"AllGather + per-source slice + cat.\"\"\"\n    pack_size = world_size * max_chunk\n\n    # Pack into canonical layout: data for rank i at slot [i*max_chunk]\n    packed = torch.zeros(pack_size, device=input_tensor.device,\n                         dtype=input_tensor.dtype)\n    send_off = 0\n    for i in range(world_size):\n        sc = send_counts[i]\n        if sc > 0:\n            packed[i * max_chunk:i * max_chunk + sc] =                 input_tensor[send_off:send_off + sc]\n        send_off += sc\n\n    # Single all_gather: collect packed buffers from all ranks\n    gathered = xm.all_gather(packed.unsqueeze(0), dim=0).view(-1)\n\n    # Slice: for each source, extract the data it sent to this rank\n    chunks = []\n    for src in range(world_size):\n        count = recv_counts[src]\n        base = src * pack_size + rank * max_chunk\n        chunks.append(gathered[base:base + count])\n\n    return torch.cat(chunks)\n"
    }
  },
  {
    "template": "evolved_allgather_reduce_scatter",
    "cost_score": 2.29,
    "sim_time_us": 229.0,
    "num_steps": 1,
    "num_collective_permute": 0,
    "num_all_gather": 1,
    "name": "evo:allgather_reduce_scatter",
    "params": {
      "evolved_code": "def evolved_alltoallv(input_tensor, send_counts, recv_counts, max_chunk,\n                      rank, world_size, num_devices, cores_per_device,\n                      xm, torch, num_nodes=1):\n    pack_size = world_size * max_chunk\n\n    packed = torch.zeros(pack_size, device=input_tensor.device,\n                         dtype=input_tensor.dtype)\n    send_off = 0\n    for i in range(world_size):\n        sc = send_counts[i]\n        if sc > 0:\n            packed[i * max_chunk:i * max_chunk + sc] = \\\n                input_tensor[send_off:send_off + sc]\n        send_off += sc\n\n    gathered = xm.all_gather(packed.unsqueeze(0), dim=0).view(-1)\n\n    flat_idx = []\n    for src in range(world_size):\n        count = recv_counts[src]\n        base = src * pack_size + rank * max_chunk\n        flat_idx.extend(range(base, base + count))\n\n    idx_tensor = torch.tensor(flat_idx, device=input_tensor.device,\n                              dtype=torch.long)\n    return torch.index_select(gathered, 0, idx_tensor)"
    }
  },
  {
    "template": "evolved_permute_ring",
    "cost_score": 2.29,
    "sim_time_us": 229.0,
    "num_steps": 1,
    "num_collective_permute": 0,
    "num_all_gather": 1,
    "name": "evo:permute_ring",
    "params": {
      "evolved_code": "def evolved_alltoallv(input_tensor, send_counts, recv_counts, max_chunk,\n                      rank, world_size, num_devices, cores_per_device,\n                      xm, torch, num_nodes=1):\n    pack_size = world_size * max_chunk\n\n    packed = torch.zeros(pack_size, device=input_tensor.device,\n                         dtype=input_tensor.dtype)\n    send_off = 0\n    for i in range(world_size):\n        sc = send_counts[i]\n        if sc > 0:\n            packed[i * max_chunk:i * max_chunk + sc] = \\\n                input_tensor[send_off:send_off + sc]\n        send_off += sc\n\n    gathered = xm.all_gather(packed.unsqueeze(0), dim=0).view(-1)\n\n    # Build flat index list in Python, single index_select\n    flat_idx = []\n    for src in range(world_size):\n        count = recv_counts[src]\n        if count > 0:\n            base = src * pack_size + rank * max_chunk\n            flat_idx.extend(range(base, base + count))\n\n    if not flat_idx:\n        return torch.zeros(0, device=input_tensor.device, dtype=input_tensor.dtype)\n\n    idx_tensor = torch.tensor(flat_idx, device=input_tensor.device, dtype=torch.long)\n    return torch.index_select(gathered, 0, idx_tensor)"
    }
  },
