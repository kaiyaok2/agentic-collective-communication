def evolved_ring_kv(kv_chunk, rank, world_size, num_devices,
                    cores_per_device, xm, torch, num_nodes=1):
    """Flat all_gather approach."""
    gathered = xm.all_gather(kv_chunk.unsqueeze(0), dim=0)
    return gathered.view(-1)
