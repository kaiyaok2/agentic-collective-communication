                    return False, (
                        f"VALUE MISMATCH: world={ws} pattern={pattern} "
                        f"rank={rank}: max_diff={diff.max():.6f} "
                        f"at index {max_diff_idx}")

            if verbose:
                print(f"  PASS: world={ws} pattern={pattern}")

    return True, "All correctness tests passed"


