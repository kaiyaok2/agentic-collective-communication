                sim.resolve()

            sim.set_phase("resolve")
            outputs = []
            for rank in range(ws):
                send_counts = matrix[rank]
                recv_counts = [matrix[src][rank] for src in range(ws)]
                nccl_mock = sim.make_nccl_module(rank)
                input_np = inputs[rank].clone().numpy()
